PORT=3001
BESCO_MODEL_PROVIDER=gemini
BESCO_CORS_ORIGINS=http://localhost:4200,http://localhost:5173
BESCO_GEMINI_API_KEY=your_api_key_here
BESCO_GEMINI_MODEL=gemini-2.5-pro
BESCO_GEMINI_MODEL_PRO=gemini-2.5-pro
BESCO_GEMINI_MODEL_FLASH=gemini-2.5-flash
# Optional: multiple Gemini tokens (comma separated)
# BESCO_GEMINI_API_KEYS=key1,key2,key3
BESCO_GEMINI_ENDPOINT_MODE=vertex
BESCO_GEMINI_API_BASE=https://aiplatform.googleapis.com
BESCO_GEMINI_API_VERSION=v1/publishers/google
# If you use Google AI Studio API key instead of Vertex, set:
# BESCO_GEMINI_ENDPOINT_MODE=gemini
# BESCO_GEMINI_API_BASE=https://generativelanguage.googleapis.com
# BESCO_GEMINI_API_VERSION=v1beta
# Optional: use OAuth token instead of API key
# BESCO_GEMINI_ACCESS_TOKEN=ya29....
# Optional request timeout in seconds (preferred).
# For long stage_1/stage_2 responses use at least 420.
# BESCO_REQUEST_TIMEOUT_SEC=420
# Legacy timeout in ms (supported for compatibility)
# BESCO_GEMINI_TIMEOUT_MS=420000
# Optional generation config override (must be JSON object)
# BESCO_GEMINI_GENERATION_CONFIG={"temperature":0.85,"responseMimeType":"application/json"}
# Optional fallback to mock if Gemini fails
# BESCO_GEMINI_FAILOVER_TO_MOCK=false

# Optional xAI/Grok routing for sexuality-heavy generation in stage_2/stage_3.
# If BESCO_XAI_API_KEY is set, those prompts will prefer xAI first and fall back to Gemini only on xAI failure.
# BESCO_XAI_API_KEY=your_xai_api_key_here
# BESCO_XAI_API_BASE=https://api.x.ai/v1
# BESCO_XAI_MODEL=grok-4-1-fast
# BESCO_XAI_MODEL_PRO=grok-4-1-fast
# BESCO_XAI_MODEL_FLASH=grok-4-1-fast
# BESCO_XAI_TIMEOUT_MS=420000
# BESCO_XAI_FOR_SEXUAL_CONTENT=true

# Legacy aliases (optional, for compatibility):
# GEMINI_API_KEY=your_api_key_here
# GEMINI_MODEL=gemini-2.5-pro
# GEMINI_ACCESS_TOKEN=ya29....
